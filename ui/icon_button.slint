import { Theme } from "theme.slint";

export component IconButton inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    callback clicked();
    
    // 固定サイズにしてリレイアウトを防ぐ
    width: 65px;
    height: 65px;
    border-radius: 12px;
    background: ta.pressed ? #ffffff44 : ta.has-hover ? #ffffff22 : Theme.glass_bg;
    border-width: 1px;
    border-color: ta.has-hover ? #ffffff88 : Theme.glass_border;
    
    // アニメーションは色のみにする（ソフトウェアレンダリングで非常に軽い）
    animate background { duration: 100ms; }
    animate border-color { duration: 100ms; }

    VerticalLayout {
        alignment: center; spacing: 2px;
        Text { text: root.icon; font-size: 24px; horizontal-alignment: center; }
        // ラベルは常に表示せず、ホバー時のみ不透明度を変えるような処理は重いので、シンプルに表示切替
        if ta.has-hover: Text { text: root.label; font-size: 10px; color: Theme.text_color; horizontal-alignment: center; }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}
